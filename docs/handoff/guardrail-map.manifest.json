{
  "schema": "TbgDefaultGuardrailMap.v1",
  "policyId": "default-guardrails",
  "purpose": "Define the whole-app default guardrail map across repo hygiene, evidence claims, agent workflow, runtime safety, domain automation, and architecture.",
  "primaryDoc": "docs/handoff/default-guardrails.md",
  "layers": [
    "repo hygiene",
    "evidence and claims",
    "agent workflow",
    "runtime and game state",
    "domain automation",
    "architecture and orchestration"
  ],
  "requiredDistinctions": [
    "Build PASS does not imply Runtime PASS",
