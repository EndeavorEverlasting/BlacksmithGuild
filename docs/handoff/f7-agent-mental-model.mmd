%% The Blacksmith Guild - F7 agent mental model
%% Purpose: keep agent letters, roles, lanes, and handoffs consistent.
%% Doctrine: No manifest, no medal. Build PASS is not game PASS.

flowchart TD
    Start([main post-PR7 PR10<br/>3384c7d product baseline])
    AssistPass[[Assist PASS landed<br/>004036 setup + 020821 attach-only]]

    subgraph Agents[Agent letters and role aliases]
        A["Agent A<br/>Cert and evidence lane<br/>Aliases: Cert, Evidence, Git, PR"]
        B["Agent B<br/>Runtime survival lane<br/>Aliases: Runtime, Readiness, Gameplay safety"]
        C["Agent C<br/>Runner and launcher lane<br/>Aliases: Launcher, F7 runner, Classifier"]
        D["Agent D<br/>Atlas and coordination lane<br/>Aliases: Docs, Atlas, Integration"]
    end

    subgraph Parallel[Parallel work that is allowed]
        Aprep["A idle until B execute lands<br/>then cert evidence + PR"]
        Bwork["B travel trade execute path<br/>new feature branch from main"]
        Cwork["C idle<br/>return on runner attach harvest defects"]
        Dwork["D atlas sync DONE<br/>coordination board current"]
    end

    subgraph Evidence[Current evidence pattern]
        E020821["20260624-020821<br/>attach-only PASS<br/>launchUsed=false<br/>mode=assistive_attach"]
        E004036["20260624-004036<br/>setup path PASS<br/>advisory_only"]
        E205925["20260623-205925<br/>old F7 CLOSED<br/>infra smoke only"]
    end

    subgraph Integration[Controlled integration]
        PullLatest["Each lane pulls latest main<br/>before commit"]
        Static["Static gates<br/>dotnet build<br/>grep guard<br/>runner contract"]
        CommitPush["Commit lane work<br/>push feature branch"]
        Reconcile["Reconcile shared docs<br/>especially f7-agent-coordination.md"]
    end

    subgraph Cert[Live cert gates]
        InfraOpt["Optional F7 infra validation<br/>~15s semantic FAIL<br/>not product medal"]
        ExecuteCert["Execute path cert<br/>after B implements travel trade"]
        Manifest["Manifest verdict only"]
        Pass["PASS criteria per execute spec<br/>honest gameplay deltas"]
        Fail["FAIL evidence committed<br/>route by manifest fields"]
    end

    subgraph Routing[Failure routing rules]
        RouteB["Route B<br/>execute path<br/>runtime readiness"]
        RouteC["Route C<br/>runner classifier<br/>launcher timing"]
        RouteA["Route A<br/>gameplay cert evidence<br/>PR gate"]
        RouteD["Route D<br/>docs drift<br/>atlas stale"]
    end

    Start --> AssistPass
    AssistPass --> Agents
    Agents --> Parallel
    A --> Aprep
    B --> Bwork
    C --> Cwork
    D --> Dwork

    Evidence --> Bwork
    Evidence --> Aprep
    Evidence --> Dwork

    E020821 --> AssistPass
    E004036 --> AssistPass
    E205925 --> InfraOpt

    Aprep --> PullLatest
    Bwork --> PullLatest
    Cwork --> PullLatest
    Dwork --> PullLatest
    PullLatest --> Static
    Static --> CommitPush
    CommitPush --> Reconcile
    Reconcile --> ExecuteCert
    Reconcile --> InfraOpt

    ExecuteCert --> Manifest
    InfraOpt --> Manifest
    Manifest --> Pass
    Manifest --> Fail
    Fail --> Routing

    Fail --> RouteB
    Fail --> RouteC
    Fail --> RouteA
    Fail --> RouteD

    RouteB --> Bwork
    RouteC --> Cwork
    RouteA --> Aprep
    RouteD --> Dwork

    classDef agent fill:#eef,stroke:#335,stroke-width:1px
    classDef work fill:#efe,stroke:#363,stroke-width:1px
    classDef evidence fill:#ffe,stroke:#663,stroke-width:1px
    classDef gate fill:#fee,stroke:#633,stroke-width:1px

    class A,B,C,D agent
    class Aprep,Bwork,Cwork,Dwork work
    class E020821,E004036,E205925 evidence
    class AssistPass,Manifest,Pass,Fail gate
