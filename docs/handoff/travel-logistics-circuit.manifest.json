  "townUtilityOrder": [
    "food_check",
    "horse_capacity_check",
    "sell_or_reduce_inventory_pressure",
    "buy_trade_goods_when_supported",
    "smith_refine_smelt_or_rest_when_legal",
    "select_next_route_after_town_exhausted"
  ],
  "downstreamUntilTravelReliable": [
    "food automation",
    "horse buying and pack capacity decisions",
    "trade buying and selling loops",
    "route profit optimization",
    "town exhaustion optimization",
    "multi-town economic loops"
  ],
  "knownGaps": [
    {
      "gap": "manual_intervention_resume",
      "reason": "Live run reached auto-travel, encountered looters, required user movement, and did not provide a clean handoff back to automation."
    },
    {
      "gap": "arrival_to_town_mechanics_transition",
      "reason": "Travel proof must transition into town utility before selecting new travel."
    },
    {
      "gap": "movement_proof_breadth",
      "reason": "partyMovedDistance == 0 alone is not enough to prove no movement occurred."
    }
  ],
  "agentInstruction": "Do not start trade optimization before travel, manual intervention resume, arrival detection, and town mechanics transition are reliable.",
  "nextRecommendedSprints": [
    "manual intervention resume",
    "arrival detection",
    "town exhaustion loop",
    "food, horse, and capacity logistics",
    "trade loop"
  ]
