{
  "schema": "tbg.harness.policy-reporting.v1",
  "id": "effective-policy-english",
  "version": 1,
  "lane": "harness/reporting/english-renderer",
  "primaryFormat": "english_markdown",
  "secondaryFormat": "raw_json",
  "resultPathPattern": "artifacts/latest/{profileId}.result.json",
  "reportPathPattern": "artifacts/latest/{profileId}.report.md",
  "defaultProofLevel": "static_harness",
  "defaultValidationMode": "offline",
  "runtimeProofLevel": "runtime_contract",
  "runtimeValidationMode": "contract_and_runtime",
  "handoffFields": [
    "effectivePolicy",
    "englishSummary",
    "sourceFiles",
    "consumerSurfaces",
    "blockedReason",
    "nextPatchHint"
  ],
  "runtimeTestHandoffSequence": [
    "workspace-decision",
    "effective-policy-context",
    "runtime-state-preflight",
    "save-load",
    "campaign-map-travel",
    "town-entry",
    "visible-trading",
    "linked-english-and-json-result"
  ],
  "ciSurfacePaths": [
    ".tbg/harness/**",
    ".tbg/workflows/**",
    ".tbg/guardrails/**",
    "scripts/harness/**",
    "scripts/mcp/**",
    "scripts/tbg/**",
    "docs/architecture/**",
    "docs/handoff/**",
    ".github/workflows/**",
    "CLAUDE.md",
    ".claude/hooks/**"
  ],
  "sourceFiles": [
    ".tbg/harness/manifest.json",
    ".tbg/harness/policies/policy-reporting.policy.json",
    ".tbg/harness/policies/command-safety.policy.json",
    ".tbg/harness/policies/evidence-gates.policy.json",
    ".tbg/harness/policies/file-safety.policy.json",
    ".tbg/harness/policies/runtime-scope.policy.json",
    ".tbg/harness/schemas/sprint-workspace-decision.schema.json",
    ".tbg/harness/fixtures/sprint-workspace.fixtures.json",
    ".tbg/guardrails/runtime-state.guardrail.json",
    ".tbg/workflows/local-mcp-code-intelligence.contract.json",
    ".tbg/workflows/project-ai-layer.contract.json",
    ".tbg/workflows/route-visible-start.contract.json"
  ],
  "consumerSurfaces": [
    "scripts/harness/Write-TbgHarnessResult.ps1",
    "scripts/harness/Test-TbgHarnessReadiness.ps1",
    "scripts/harness/Test-TbgDoneGate.ps1",
    "scripts/harness/Test-TbgCommandSafety.ps1",
    "scripts/harness/Test-TbgFileSafety.ps1",
    "scripts/harness/Test-TbgWorkflowGate.ps1",
    "scripts/harness/Get-TbgHarnessContext.ps1",
    "scripts/harness/Invoke-TbgHarness.ps1",
    "scripts/harness/TbgEffectivePolicy.psm1",
    "scripts/harness/Get-TbgEffectivePolicyContext.ps1",
    "scripts/harness/ConvertTo-TbgPolicyEnglish.ps1",
    "scripts/harness/Test-TbgEnglishRenderer.ps1",
    "scripts/harness/TbgSprintWorkspace.psm1",
    "scripts/harness/Resolve-TbgSprintWorkspace.ps1",
    "scripts/harness/Test-TbgSprintWorkspace.ps1"
  ]
}
