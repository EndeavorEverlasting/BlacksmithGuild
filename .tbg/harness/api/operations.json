      "mode": "read-only",
      "requiredInputs": [],
      "outputArtifacts": [
        "artifacts/latest/e2e-harness/e2e-harness.result.json"
      ],
      "riskClass": "static",
      "proofCeiling": "static test"
    },
    {
      "id": "run-end-to-end-profile",
      "entrypoint": "scripts/tbg/Invoke-TbgEndToEndValidation.ps1",
