      "mode": "local-transform",
      "requiredInputs": ["sprintId", "lane", "mission", "proofLevel", "proofCeiling", "nextCommand"],
      "outputArtifacts": [
        "artifacts/latest/tbg-sprint-capsule.json"
      ],
      "riskClass": "static",
      "proofCeiling": "contract"
    },
    {
      "id": "validate-window-lifecycle-runtime",
      "entrypoint": "scripts/tbg/Test-TbgWindowLifecycleRuntime.ps1",
      "mode": "read-only",
      "requiredInputs": [],
      "outputArtifacts": [
        "artifacts/latest/window-lifecycle/"
      ],
      "riskClass": "static",
      "proofCeiling": "static test"
    },
    {
      "id": "replay-window-lifecycle-fixture",
      "entrypoint": "ForgeWindowLifecycle.cmd",
      "mode": "read-only",
      "requiredInputs": ["replay"],
      "outputArtifacts": [
        "artifacts/latest/window-lifecycle/window-lifecycle.result.json",
        "artifacts/latest/window-lifecycle/window-lifecycle.state.json",
        "artifacts/latest/window-lifecycle/window-lifecycle.report.md"
      ],
      "riskClass": "static",
      "proofCeiling": "harness"
    },
    {
      "id": "inspect-window-lifecycle-status",
