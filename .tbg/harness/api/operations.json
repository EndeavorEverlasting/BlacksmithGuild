{
  "schema": "tbg.harness.operations.v1",
  "operations": [
    {
      "id": "validate-end-to-end-harness",
      "entrypoint": "scripts/tbg/Test-TbgEndToEndHarness.ps1",
      "mode": "read-only",
      "requiredInputs": [],
      "outputArtifacts": [
        "artifacts/latest/e2e-harness/e2e-harness.result.json"
      ],
      "riskClass": "static",
      "proofCeiling": "static test"
    },
    {
      "id": "run-end-to-end-profile",
      "entrypoint": "scripts/tbg/Invoke-TbgEndToEndValidation.ps1",
      "mode": "profile-gated",
      "requiredInputs": ["profile"],
      "outputArtifacts": [
        "artifacts/latest/e2e-validation/"
      ],
      "riskClass": "static",
      "proofCeiling": "profile-dependent"
    },
    {
      "id": "generate-sprint-capsule",
      "entrypoint": "scripts/tbg/New-TbgSprintCapsule.ps1",
      "mode": "local-transform",
      "requiredInputs": ["sprintId", "lane", "mission", "proofLevel", "proofCeiling", "nextCommand"],
      "outputArtifacts": [
        "artifacts/latest/tbg-sprint-capsule.json"
      ],
      "riskClass": "static",
      "proofCeiling": "contract"
    },
    {
      "id": "validate-window-lifecycle-runtime",
      "entrypoint": "scripts/tbg/Test-TbgWindowLifecycleRuntime.ps1",
      "mode": "read-only",
      "requiredInputs": [],
      "outputArtifacts": [
        "artifacts/latest/window-lifecycle/"
      ],
      "riskClass": "static",
      "proofCeiling": "static test"
    },
    {
      "id": "replay-window-lifecycle-fixture",
      "entrypoint": "ForgeWindowLifecycle.cmd",
      "mode": "read-only",
      "requiredInputs": ["replay"],
      "outputArtifacts": [
        "artifacts/latest/window-lifecycle/window-lifecycle.result.json",
        "artifacts/latest/window-lifecycle/window-lifecycle.state.json",
        "artifacts/latest/window-lifecycle/window-lifecycle.report.md"
      ],
      "riskClass": "static",
      "proofCeiling": "harness"
    },
    {
      "id": "inspect-window-lifecycle-status",
      "entrypoint": "ForgeWindowLifecycle.cmd",
      "mode": "read-only",
      "requiredInputs": ["status"],
      "outputArtifacts": [
        "artifacts/latest/window-lifecycle/window-lifecycle.handoff.md"
      ],
      "riskClass": "static",
      "proofCeiling": "harness"
    },
    {
      "id": "start-runtime-observer",
      "entrypoint": "ForgeRuntimeObserver.cmd / Start-TbgGameRuntimeObserver.ps1",
      "mode": "owned-observer-start",
      "requiredInputs": ["completed-or-active read-only observation scope"],
      "outputArtifacts": [".local/tbg-runtime-observer/<runId>/run-context.json", ".local/tbg-runtime-observer/<runId>/observer-status.json"],
      "riskClass": "runtime_read",
      "proofCeiling": "harness",
      "ownershipLease": "Creates only an observer lease under .local/tbg-runtime-observer; it owns neither Bannerlord nor its launcher.",
      "forbiddenConditions": ["Do not launch, stop, restart, kill, click, focus, or save.", "Do not infer live certification from observer startup."]
    },
    {
      "id": "inspect-runtime-observer-status",
      "entrypoint": "ForgeRuntimeObserver.cmd status",
      "mode": "read-only",
      "requiredInputs": [],
      "outputArtifacts": [".local/tbg-runtime-observer/<runId>/observer-status.json"],
      "riskClass": "runtime_read",
      "proofCeiling": "harness",
      "ownershipLease": "Reads observer status only; Bannerlord ownership is never inferred.",
      "forbiddenConditions": ["Process presence is not cleanup authority.", "Observer absence is not negative-evidence confidence."]
    },
    {
      "id": "stop-owned-runtime-observer",
      "entrypoint": "ForgeRuntimeObserver.cmd stop",
      "mode": "owned-observer-stop",
      "requiredInputs": ["matching owned observer lease"],
      "outputArtifacts": [".local/tbg-runtime-observer/<runId>/observer-status.json"],
      "riskClass": "local_read_write",
      "proofCeiling": "harness",
      "ownershipLease": "May stop only the matching harness-owned observer lease; NEVER stops Bannerlord.",
      "forbiddenConditions": ["Never terminate Bannerlord, its launcher, or a human, foreign, or ambiguous process.", "Do not treat observer stop as incident resolution."]
    },
    {
      "id": "validate-runtime-event-observation",
      "entrypoint": "scripts/tbg/Test-TbgRuntimeEventObservation.ps1",
      "mode": "read-only",
      "requiredInputs": [],
      "outputArtifacts": ["artifacts/latest/runtime-observer/runtime-event-observation.result.json"],
      "riskClass": "static",
      "proofCeiling": "static test",
      "ownershipLease": "None; fixture validation only.",
      "forbiddenConditions": ["No observer execution, process action, proof promotion, or live-runtime claim."]
    },
    {
      "id": "assemble-runtime-incident",
      "entrypoint": "Resolve-TbgRuntimeIncident.ps1 / ForgeRuntimeIncident.cmd",
      "mode": "read-only",
      "requiredInputs": ["completed observer run root"],
      "outputArtifacts": [".local/tbg-runtime-observer/<runId>/incident-timeline.json", ".local/tbg-runtime-observer/<runId>/incident-result.json", "artifacts/latest/runtime-incident/runtime-incident-assembler.result.json"],
      "riskClass": "runtime_read",
      "proofCeiling": "harness",
      "ownershipLease": "Consumes a bounded completed observer run; it acquires no game, launcher, or process ownership.",
      "forbiddenConditions": ["No restart, kill, click, focus, save, command-inbox, or root-cause promotion.", "Stale logs and window disappearance do not confirm a crash."]
    },
    {
      "id": "validate-runtime-incident",
      "entrypoint": "scripts/tbg/Test-TbgRuntimeIncidentAssembler.ps1",
      "mode": "read-only",
      "requiredInputs": [],
      "outputArtifacts": ["artifacts/latest/runtime-incident/runtime-incident-assembler.result.json"],
      "riskClass": "static",
      "proofCeiling": "static test",
      "ownershipLease": "None; deterministic fixture replay only.",
      "forbiddenConditions": ["No live process observation or certification.", "No proof promotion from fixture outcomes."]
    },
    {
      "id": "inspect-runtime-incident-status",
      "entrypoint": "Resolve-TbgRuntimeIncident.ps1 / ForgeRuntimeIncident.cmd",
      "mode": "read-only",
      "requiredInputs": ["completed observer run root"],
      "outputArtifacts": [".local/tbg-runtime-observer/<runId>/incident-result.json"],
      "riskClass": "runtime_read",
      "proofCeiling": "harness",
      "ownershipLease": "Reads completed incident output; no ownership is acquired.",
      "forbiddenConditions": ["incident_ready is not live certification.", "Do not convert observer gaps into negative-evidence confidence."]
    },
    {
      "id": "run-one-click-test",
      "entrypoint": "ForgeTest.cmd",
      "mode": "profile-gated",
      "requiredInputs": [],
      "outputArtifacts": [
        ".local/tbg-one-click-tests/<runId>/run-context.json",
        ".local/tbg-one-click-tests/<runId>/events.jsonl",
        ".local/tbg-one-click-tests/<runId>/discovered-tests.json",
        ".local/tbg-one-click-tests/<runId>/result.json",
        ".local/tbg-one-click-tests/<runId>/operator-report.md",
        "artifacts/latest/one-click-test/"
      ],
      "riskClass": "static",
      "proofCeiling": "profile-dependent"
    },
    {
      "id": "list-one-click-tests",
      "entrypoint": "ForgeTest.cmd",
      "mode": "read-only",
      "requiredInputs": ["list"],
      "outputArtifacts": [],
      "riskClass": "static",
      "proofCeiling": "contract"
    },
    {
      "id": "validate-one-click-test-spine",
      "entrypoint": "scripts/tbg/Test-TbgOneClickTestSpine.ps1",
      "mode": "read-only",
      "requiredInputs": [],
      "outputArtifacts": [
        "artifacts/latest/one-click-test/one-click-test-spine.validation.json"
      ],
      "riskClass": "static",
      "proofCeiling": "static test"
    }
  ]
}
