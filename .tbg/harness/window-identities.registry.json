{
  "schema": "TbgWindowIdentityRegistry.v1",
  "version": "1.2.0",
  "repository": "EndeavorEverlasting/BlacksmithGuild",
  "purpose": "Classify every correlated Bannerlord, launcher, calibration, modal, Steam-broker, and game-handoff window from process, HWND, Win32, UI Automation, dependency, and learned-alias metadata before any coordinate or image fallback is considered.",
  "defaultPolicy": {
    "minimumRecognitionScore": 70,
    "minimumAutomaticActionScore": 90,
    "pollMilliseconds": 100,
    "maximumControls": 256,
    "cacheHighConfidenceMatches": true,
    "unknownWindowDisposition": "delta_discovery_required",
    "imageFallbackDisposition": "diagnostic_only",
    "recordAllCorrelatedTopLevelWindows": true,
    "freezeIdentityPerSurfaceOperation": true
  },
  "launchPathInvariance": {
    "entryPaths": ["forge_continue", "auto_launch_nav", "new_game_play", "steam_mediated", "future_registered_path"],
    "requiredSurfaceClasses": [
      "play_continue_menu",
      "calibration_menu",
      "safe_mode_window",
      "caution_window",
      "steam_broker_window",
      "other_launcher_window",
      "singleplayer_handoff"
    ],
    "unknownSurfaceDisposition": "unknown_quarantined",
    "missingObservationDisposition": "unknown_not_absent"
  },
  "lifecycle": {
    "stateSchema": ".tbg/harness/schemas/window-lifecycle-state.schema.json",
    "transitionSchema": ".tbg/harness/schemas/window-lifecycle-transition.schema.json",
    "reducer": "scripts/tbg/Resolve-TbgWindowLifecycle.ps1",
    "fixture": ".tbg/harness/fixtures/window-intelligence/window-lifecycle-sequences.fixture.json",
    "initialState": "unseen",
    "terminalStates": ["terminal_observation", "disappeared", "blocked"],
    "unknownState": "unknown_quarantined"
  },
  "normalization": {
    "caseInsensitive": true,
    "collapseWhitespace": true,
    "stripVersionBuildNoise": false,
    "versionSegments": 4
  },
  "identities": [
    {
      "id": "bannerlord.launcher.menu",
      "displayName": "Bannerlord launcher menu",
      "surfaceClass": "play_continue_menu",
      "lifecycleRole": "context_owned_interactive",
      "aliases": [
        "Mount & Blade II: Bannerlord",
        "Mount and Blade II Bannerlord",
        "M&B II: Bannerlord",
        "TaleWorlds.MountAndBlade.Launcher"
      ],
      "match": {
        "processNames": ["TaleWorlds.MountAndBlade.Launcher"],
        "titleRegex": ["(?i)bannerlord"],
        "anyControlNames": ["PLAY", "CONTINUE"],
        "allTextRegex": [],
        "anyTextRegex": ["(?i)play", "(?i)continue"],
        "dependencyMismatch": false,
        "minimumDirectSignals": 2
      },
      "actionPolicy": {
        "kind": "context_owned",
        "description": "The launch intent comes from launcher-window-context.json. Window intelligence must not guess PLAY versus CONTINUE.",
        "automatic": false,
        "minimumScore": 0,
        "preferredControlNames": [],
        "fallbackKeys": [],
        "fallbackRequiresForegroundAuthority": false,
        "requiredDirectSignals": [],
        "forbiddenFallbacks": ["rescore spawned game as launcher", "infer continue from stale evidence", "blind coordinate click"]
      }
    },
    {
      "id": "bannerlord.launcher.calibration",
      "displayName": "Bannerlord launcher calibration menu",
      "surfaceClass": "calibration_menu",
      "lifecycleRole": "context_owned_interactive",
      "aliases": [
        "Calibration",
        "Launcher Calibration",
        "Calibrate"
      ],
      "match": {
        "processNames": ["TaleWorlds.MountAndBlade.Launcher", "Bannerlord"],
        "titleRegex": ["(?i)calibrat"],
        "anyControlNames": ["Calibrate", "Continue", "Confirm", "Skip"],
        "allTextRegex": [],
        "anyTextRegex": ["(?i)calibrat"],
        "dependencyMismatch": false,
        "minimumDirectSignals": 2
      },
      "actionPolicy": {
        "kind": "context_owned_observation",
        "description": "Record calibration as a first-class launcher surface. Do not automate it until an exact workflow-owned semantic action, named controls, expected transition, and fixture are registered.",
        "automatic": false,
        "minimumScore": 0,
        "preferredControlNames": [],
        "fallbackKeys": [],
        "fallbackRequiresForegroundAuthority": true,
        "requiredDirectSignals": [],
        "forbiddenFallbacks": ["guess calibration choice", "blind coordinate click", "reuse PLAY or CONTINUE coordinates"]
      }
    },
    {
      "id": "bannerlord.dependency-version-caution",
      "displayName": "Blacksmith Guild dependency-version caution",
      "surfaceClass": "caution_window",
      "lifecycleRole": "known_modal",
      "aliases": [
        "CAUTION",
        "Caution",
        "Dependency Warning",
        "Module version warning",
        "Version mismatch caution"
      ],
      "match": {
        "processNames": ["TaleWorlds.MountAndBlade.Launcher", "Bannerlord"],
        "titleRegex": [],
        "anyControlNames": ["Confirm", "Cancel"],
        "allTextRegex": [
          "(?i)the blacksmith guild depends on",
          "(?i)current version is",
          "(?i)are you sure"
        ],
        "anyTextRegex": ["(?i)caution", "(?i)native", "(?i)sandboxcore", "(?i)storymode"],
        "dependencyMismatch": true,
        "minimumDirectSignals": 3
      },
      "extractors": [
        {
          "id": "dependency-version-lines",
          "regex": "(?i)(?<module>Native|SandBoxCore|Sandbox|StoryMode).*?depends on.*?v(?<expected>[0-9.]+).*?current version is.*?v(?<current>[0-9.]+)"
        }
      ],
      "actionPolicy": {
        "kind": "known_modal_action",
        "actionId": "confirm_dependency_version_caution",
        "semanticAction": "confirm",
        "automatic": true,
        "minimumScore": 90,
        "preferredControlNames": ["Confirm"],
        "fallbackKeys": ["ENTER"],
        "fallbackRequiresForegroundAuthority": true,
        "requiredDirectSignals": ["caution_text_or_control", "confirm_control", "dependency_mismatch"],
        "description": "Confirm the known Blacksmith Guild dependency-version caution only after the exact modal identity and Confirm control are present. A predicted mismatch without a visible modal is not action authority."
      }
    },
    {
      "id": "bannerlord.safe-mode",
      "displayName": "Bannerlord Safe Mode prompt",
      "surfaceClass": "safe_mode_window",
      "lifecycleRole": "known_modal",
      "aliases": ["Safe Mode", "Bannerlord Safe Mode", "Launch in Safe Mode"],
      "match": {
        "processNames": ["TaleWorlds.MountAndBlade.Launcher", "Bannerlord"],
        "titleRegex": ["(?i)^safe mode$", "(?i)safe mode"],
        "anyControlNames": ["No", "Yes"],
        "allTextRegex": [],
        "anyTextRegex": ["(?i)safe mode"],
        "dependencyMismatch": false,
        "minimumDirectSignals": 2
      },
      "actionPolicy": {
        "kind": "known_modal_action",
        "actionId": "decline_safe_mode",
        "semanticAction": "decline",
        "automatic": true,
        "minimumScore": 70,
        "preferredControlNames": ["No"],
        "fallbackKeys": ["ALT+N"],
        "fallbackRequiresForegroundAuthority": true,
        "requiredDirectSignals": ["safe_mode_title_or_text", "no_control"],
        "description": "Decline Safe Mode and continue the normal launch path only when the Safe Mode text and exact No control are present. Do not use Cancel or Alt+C."
      }
    },
    {
      "id": "steam.launch-broker",
      "displayName": "Steam Bannerlord launch broker",
      "surfaceClass": "steam_broker_window",
      "lifecycleRole": "launch_broker_observation",
      "aliases": [
        "Steam",
        "Steam Client",
        "Steam launch broker",
        "steamwebhelper"
      ],
      "match": {
        "processNames": ["steam", "steamwebhelper"],
        "titleRegex": ["(?i)steam"],
        "anyControlNames": [],
        "allTextRegex": [],
        "anyTextRegex": ["(?i)mount.*blade", "(?i)bannerlord", "(?i)launching"],
        "dependencyMismatch": false,
        "minimumDirectSignals": 2,
        "correlationRequired": true,
        "correlationSignals": [
          "owned_launch_request",
          "fresh_launch_time_window",
          "parent_child_process_evidence",
          "verified_executable_path",
          "s1_s2_process_or_window_delta"
        ]
      },
      "actionPolicy": {
        "kind": "observation_only",
        "description": "Record a Steam window only when it is correlated to the active Bannerlord launch. Never click, focus, close, or otherwise interact with Steam automatically.",
        "automatic": false,
        "minimumScore": 0,
        "preferredControlNames": [],
        "fallbackKeys": [],
        "fallbackRequiresForegroundAuthority": true,
        "requiredDirectSignals": ["steam_process", "active_launch_correlation"],
        "forbiddenFallbacks": ["global Steam window enumeration", "automatic Steam click", "foreground Steam", "close Steam"]
      }
    },
    {
      "id": "bannerlord.singleplayer-host",
      "displayName": "Bannerlord Singleplayer host",
      "surfaceClass": "singleplayer_handoff",
      "lifecycleRole": "terminal_handoff",
      "aliases": [
        "Mount and Blade II Bannerlord - Singleplayer",
        "Mount & Blade II: Bannerlord - Singleplayer",
        "Bannerlord Singleplayer"
      ],
      "match": {
        "processNames": ["TaleWorlds.MountAndBlade.Launcher", "Bannerlord"],
        "titleRegex": ["(?i)bannerlord.*singleplayer"],
        "anyControlNames": [],
        "allTextRegex": ["(?i)bannerlord.*singleplayer"],
        "anyTextRegex": ["(?i)singleplayer"],
        "dependencyMismatch": false,
        "minimumDirectSignals": 2
      },
      "actionPolicy": {
        "kind": "terminal_observation",
        "automatic": false,
        "minimumScore": 0,
        "preferredControlNames": [],
        "fallbackKeys": [],
        "fallbackRequiresForegroundAuthority": false,
        "requiredDirectSignals": [],
        "description": "Stop launcher clicking. This window is a game-host handoff, not a launcher menu."
      }
    }
  ]
}
