{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/EndeavorEverlasting/BlacksmithGuild/.tbg/harness/schemas/objective.schema.json",
  "title": "TBG Objective v1",
  "description": "A product or sprint outcome, independent of who works on it.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "id",
    "statement",
    "acceptanceCriteria",
    "forbiddenShortcuts",
    "status"
  ],
  "properties": {
    "schema": {
      "const": "TbgObjective.v1"
    },
    "id": {
      "type": "string",
      "pattern": "^objective:[a-z0-9]+(?:-[a-z0-9]+)*$"
    },
    "statement": {
      "type": "string",
      "minLength": 1
    },
    "acceptanceCriteria": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "forbiddenShortcuts": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "status": {
      "enum": ["active", "completed", "superseded", "abandoned"]
    },
    "version": {
      "type": "integer",
      "minimum": 1,
      "default": 1
    },
    "supersedes": {
      "type": "string"
    },
    "producedUtc": {
      "type": "string",
      "format": "date-time"
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
