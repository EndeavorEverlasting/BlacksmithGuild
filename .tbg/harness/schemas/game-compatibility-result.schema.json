{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/EndeavorEverlasting/BlacksmithGuild/.tbg/harness/schemas/game-compatibility-result.schema.json",
  "title": "TBG Game Compatibility Result v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema", "generatedUtc", "runId", "command", "sourceCommit",
    "upstreamAvailableBuild", "locallyInstalledBuild", "repoSupportedBuild",
    "builtModDll", "installedModDll", "comparisons", "verdict",
    "terminalState", "proofLevel", "allowedClaims", "forbiddenClaims",
    "nextCommand", "evidencePaths"
  ],
  "properties": {
    "schema": { "const": "TbgGameCompatibilityResult.v1" },
    "generatedUtc": { "type": "string", "format": "date-time" },
    "runId": { "type": "string", "minLength": 1 },
    "command": { "enum": ["check", "reconcile", "offline"] },
    "sourceCommit": { "type": "object" },
    "upstreamAvailableBuild": { "type": "object" },
    "locallyInstalledBuild": { "type": "object" },
    "repoSupportedBuild": { "type": "object" },
    "builtModDll": { "type": "object" },
    "installedModDll": { "type": "object" },
    "comparisons": { "type": "object" },
    "verdict": { "enum": ["PASS", "ATTENTION", "BLOCKED"] },
    "terminalState": { "type": "string", "minLength": 1 },
    "proofLevel": { "const": "harness" },
    "allowedClaims": { "type": "array", "items": { "type": "string" } },
    "forbiddenClaims": { "type": "array", "items": { "type": "string" } },
    "nextCommand": { "type": "string", "minLength": 1 },
    "evidencePaths": { "type": "object" }
  }
}
