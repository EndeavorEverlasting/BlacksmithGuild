{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/EndeavorEverlasting/BlacksmithGuild/.tbg/harness/schemas/work-item.schema.json",
  "title": "TBG Work Item v1",
  "description": "A bounded piece of work that advances an objective.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "id",
    "objective",
    "status",
    "requestedCapabilities",
    "preconditions",
    "ownedPaths",
    "forbiddenPaths",
    "expectedOutputs"
  ],
  "properties": {
    "schema": {
      "const": "TbgWorkItem.v1"
    },
    "id": {
      "type": "string",
      "pattern": "^work-item:[a-z0-9]+(?:-[a-z0-9]+)*$"
    },
    "objective": {
      "type": "string",
      "pattern": "^objective:"
    },
    "status": {
      "enum": ["draft", "ready", "in_progress", "blocked", "completed", "cancelled"]
    },
    "requestedCapabilities": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "pattern": "^capability:"
      }
    },
    "preconditions": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["predicate", "operator", "value"],
        "properties": {
          "predicate": {
            "type": "string",
            "minLength": 1
          },
          "operator": {
            "enum": ["equals", "not_equals", "exists", "not_exists", "greater_than"]
          },
          "value": {}
        }
      }
    },
    "ownedPaths": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "forbiddenPaths": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "expectedOutputs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "blockedBy": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "unblockWhen": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "version": {
      "type": "integer",
      "minimum": 1,
      "default": 1
    },
    "supersedes": {
      "type": "string"
    },
    "producedUtc": {
      "type": "string",
      "format": "date-time"
    }
  }
}
