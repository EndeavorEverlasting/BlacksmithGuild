{
  "schema": "tbg.one-click-test.artifact-registry.v1",
  "type": "object",
  "required": ["schema", "runId", "artifacts"],
  "properties": {
    "schema": { "type": "string", "enum": ["tbg.one-click-test.artifact-registry.v1"] },
    "runId": { "type": "string" },
    "generatedUtc": { "type": "string", "format": "date-time" },
    "artifacts": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["type", "path", "role", "hash", "freshness", "producer", "disposition", "retention"],
        "properties": {
          "type": { "type": "string" },
          "path": { "type": "string" },
          "role": { "type": "string" },
          "hash": { "type": "string" },
          "freshness": { "type": "string", "format": "date-time" },
          "producer": { "type": "string" },
          "disposition": { "type": "string", "enum": ["tracked", "ignored"] },
          "retention": { "type": "string", "enum": ["run", "session", "permanent"] }
        }
      }
    }
  }
}
