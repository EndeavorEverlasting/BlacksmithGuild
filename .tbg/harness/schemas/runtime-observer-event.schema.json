{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/EndeavorEverlasting/BlacksmithGuild/.tbg/harness/schemas/runtime-observer-event.schema.json",
  "title": "TBG Runtime Observer Event v1",
  "description": "Normalized bounded runtime observation. Event presence does not establish acceptance or root cause. A last open span is an execution boundary, not a cause. native_crash_confirmed requires correlated external terminal evidence; an assembler owns causality promotion.",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema", "version", "eventId", "runId", "commandId", "correlationId", "spanId", "parentSpanId", "observerId", "sourceKind", "eventType", "severity", "observedUtc", "sourceTimestamp", "processIdentity", "windowIdentity", "operation", "expectedSignalId", "payload", "evidenceRefs", "freshness", "proofLevel", "redactionState"],
  "properties": {
    "schema": {"const": "TbgRuntimeObserverEvent.v1"},
    "version": {"type": "integer", "const": 1},
    "eventId": {"type": "string", "minLength": 1, "maxLength": 128},
    "runId": {"type": "string", "minLength": 1, "maxLength": 128},
    "commandId": {"type": ["string", "null"], "maxLength": 128},
    "correlationId": {"type": "string", "minLength": 1, "maxLength": 128},
    "spanId": {"type": ["string", "null"], "maxLength": 128},
    "parentSpanId": {"type": ["string", "null"], "maxLength": 128},
    "observerId": {"type": "string", "minLength": 1, "maxLength": 128},
    "sourceKind": {"enum": ["window_lifecycle", "process_lifecycle", "windows_error_reporting", "taleworlds_crash", "heartbeat_log_progress", "process_responsiveness", "in_process_span", "observer_health"]},
    "eventType": {"enum": ["window.created", "window.shown", "window.hidden", "window.destroyed", "window.title_changed", "window.focus_changed", "process.started", "process.exited", "process.unobserved", "external_terminal_evidence", "heartbeat.fresh", "heartbeat.stalled", "hang.suspected", "hang.confirmed", "span.started", "span.completed", "span.error", "span.blocked", "span.abandoned", "observer.gap", "observer.reconciled", "observer.health", "process_lost"]},
    "severity": {"enum": ["info", "warning", "error", "critical"]},
    "observedUtc": {"type": "string", "format": "date-time"},
    "sourceTimestamp": {"type": ["string", "null"], "format": "date-time"},
    "processIdentity": {"type": "object", "additionalProperties": false, "required": ["canonicalName", "pid"], "properties": {"canonicalName": {"enum": ["Bannerlord", "Bannerlord.Native", "TaleWorlds.MountAndBlade", "TaleWorlds.MountAndBlade.Launcher", "unknown"]}, "pid": {"type": ["integer", "null"], "minimum": 1}}},
    "windowIdentity": {"type": ["object", "null"], "maxProperties": 8},
    "operation": {"type": ["string", "null"], "maxLength": 512},
    "expectedSignalId": {"type": ["string", "null"], "maxLength": 256},
    "payload": {"type": "object", "maxProperties": 32, "propertyNames": {"maxLength": 128}},
    "evidenceRefs": {"type": "array", "maxItems": 32, "items": {"type": "string", "minLength": 1, "maxLength": 512}},
    "freshness": {"enum": ["fresh", "stale", "unknown"]},
    "proofLevel": {"enum": ["contract", "harness", "static_test", "build", "launcher", "command_ack", "behavior_observed", "live_runtime"]},
    "redactionState": {"enum": ["none", "sanitized", "redacted"]}
  }
}
