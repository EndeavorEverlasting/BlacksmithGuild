{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/EndeavorEverlasting/BlacksmithGuild/.tbg/harness/schemas/runtime-observer-run-context.schema.json",
  "title": "TBG Runtime Observer Run Context v1",
  "description": "Canonical context for a bounded runtime-observer run. This schema records observation authority only and does not grant process, game, save, or command mutation.",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema", "runId", "correlationId", "sourceCommit", "branch", "worktreeLabel", "observers", "processIdentity", "startedUtc", "completedUtc", "mode", "authority", "proofCeiling", "artifactRoot", "redactionPolicy"],
  "properties": {
    "schema": {"const": "TbgRuntimeObserverRunContext.v1"},
    "runId": {"type": "string", "minLength": 1, "maxLength": 128},
    "correlationId": {"type": "string", "minLength": 1, "maxLength": 128},
    "sourceCommit": {"type": "string", "minLength": 7, "maxLength": 64},
    "branch": {"type": "string", "minLength": 1, "maxLength": 256},
    "worktreeLabel": {"type": ["string", "null"], "maxLength": 256},
    "observers": {"type": "array", "minItems": 1, "maxItems": 32, "items": {"type": "object", "additionalProperties": false, "required": ["observerId", "version"], "properties": {"observerId": {"type": "string", "minLength": 1, "maxLength": 128}, "version": {"type": "string", "minLength": 1, "maxLength": 64}, "sourceKind": {"type": ["string", "null"], "maxLength": 64}}}},
    "processIdentity": {"type": "object", "additionalProperties": false, "required": ["canonicalName", "pid", "imageName", "ownership"], "properties": {"canonicalName": {"enum": ["Bannerlord", "Bannerlord.Native", "TaleWorlds.MountAndBlade", "TaleWorlds.MountAndBlade.Launcher", "unknown"]}, "pid": {"type": ["integer", "null"], "minimum": 1}, "imageName": {"type": ["string", "null"], "maxLength": 256}, "ownership": {"enum": ["owned", "human", "foreign", "unknown", "stale_proven"]}}},
    "startedUtc": {"type": "string", "format": "date-time"},
    "completedUtc": {"type": ["string", "null"], "format": "date-time"},
    "mode": {"enum": ["fixture", "observe", "live-authorized"]},
    "authority": {"type": "string", "minLength": 1, "maxLength": 512},
    "proofCeiling": {"enum": ["contract", "harness", "static_test", "build", "launcher", "command_ack", "behavior_observed", "live_runtime"]},
    "artifactRoot": {"type": "string", "pattern": "^\\.local/tbg-runtime-observer/", "maxLength": 512},
    "redactionPolicy": {"type": "object", "additionalProperties": false, "required": ["rawEvidenceLocalOnly", "forbiddenContent"], "properties": {"rawEvidenceLocalOnly": {"const": true}, "forbiddenContent": {"type": "array", "minItems": 1, "maxItems": 16, "items": {"type": "string", "minLength": 1, "maxLength": 128}}}}
  }
}
