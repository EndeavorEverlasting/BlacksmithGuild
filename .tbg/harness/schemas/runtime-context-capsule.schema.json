{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/EndeavorEverlasting/BlacksmithGuild/.tbg/harness/schemas/runtime-context-capsule.schema.json",
  "title": "TbgRuntimeContextCapsule.v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema", "runId", "generatedUtc", "repo", "branch", "commitSha", "sprint", "lane", "runtimeClassification", "processes", "handoff", "failure", "evidenceRefs", "proofLevel", "redaction", "nextDecision"],
  "properties": {
    "schema": {"const": "TbgRuntimeContextCapsule.v1"},
    "runId": {"type": "string", "minLength": 1, "maxLength": 128},
    "generatedUtc": {"type": "string", "format": "date-time"},
    "repo": {"const": "EndeavorEverlasting/BlacksmithGuild"},
    "branch": {"type": "string", "minLength": 1, "maxLength": 256},
    "commitSha": {"type": "string", "pattern": "^[0-9a-fA-F]{40}$"},
    "sprint": {"type": "string", "minLength": 1, "maxLength": 256},
    "lane": {"type": "string", "minLength": 1, "maxLength": 256},
    "worktreeLabel": {"type": ["string", "null"], "maxLength": 256},
    "sessionOwner": {"type": ["string", "null"], "maxLength": 128},
    "loadedAssemblySha256": {"type": ["string", "null"], "pattern": "^([0-9a-fA-F]{64})?$"},
    "runtimeClassification": {"enum": ["absent", "active_owned", "active_human", "active_foreign", "stale_or_zombie_proven", "ambiguous"]},
    "processes": {
      "type": "array",
      "maxItems": 16,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["canonicalName", "pid", "ownership"],
        "properties": {
          "canonicalName": {"enum": ["Bannerlord", "Bannerlord.Native", "TaleWorlds.MountAndBlade", "TaleWorlds.MountAndBlade.Launcher"]},
          "pid": {"type": ["integer", "null"], "minimum": 1},
          "ownership": {"enum": ["owned", "human", "foreign", "unknown", "stale_proven"]},
          "windowIdentity": {"type": ["string", "null"], "maxLength": 256}
        }
      }
    },
    "handoff": {
      "type": "object",
      "additionalProperties": false,
      "required": ["lastCompleted", "active", "nextIntended"],
      "properties": {
        "lastCompleted": {"type": ["object", "null"]},
        "active": {"type": ["object", "null"]},
        "nextIntended": {"type": ["object", "null"]}
      }
    },
    "failure": {
      "type": "object",
      "additionalProperties": false,
      "required": ["classification", "summary", "crashObserved"],
      "properties": {
        "classification": {
          "anyOf": [
            {"type": "null"},
            {"enum": ["log_stalled", "process_unobserved", "process_exited", "managed_exception_confirmed", "native_crash_suspected", "native_crash_confirmed", "hang_confirmed", "clean_exit", "unknown_failure"]}
          ]
        },
        "summary": {"type": "string", "maxLength": 2048},
        "crashObserved": {"type": "boolean"},
        "externalTerminalEvidenceRefs": {
          "type": "array",
          "maxItems": 16,
          "items": {"type": "string", "minLength": 1, "maxLength": 256}
        }
      }
    },
    "crashObservability": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "commandId",
        "correlationId",
        "spanId",
        "parentSpanId",
        "operation",
        "startedAtUtc",
        "completedAtUtc",
        "terminalStatus",
        "preState",
        "postState",
        "expectedSignals",
        "observedSignals",
        "negativeEvidence",
        "lastMarkerBoundaryOnly",
        "balancedSpan",
        "unrelatedDoneClosedSpan",
        "causality",
        "reconstructable"
      ],
      "properties": {
        "commandId": {"type": ["string", "null"], "maxLength": 128},
        "correlationId": {"type": "string", "minLength": 1, "maxLength": 128},
        "spanId": {"type": "string", "minLength": 1, "maxLength": 128},
        "parentSpanId": {"type": ["string", "null"], "maxLength": 128},
        "operation": {"type": "string", "minLength": 1, "maxLength": 512},
        "startedAtUtc": {"type": "string", "format": "date-time"},
        "completedAtUtc": {"type": ["string", "null"], "format": "date-time"},
        "terminalStatus": {"enum": ["completed", "error", "blocked", "aborted", "process_lost", "open"]},
        "preState": {"type": "object", "maxProperties": 128},
        "postState": {"type": ["object", "null"], "maxProperties": 128},
        "expectedSignals": {
          "type": "array",
          "maxItems": 64,
          "items": {"type": "string", "minLength": 1, "maxLength": 256}
        },
        "observedSignals": {
          "type": "array",
          "maxItems": 64,
          "items": {"type": "string", "minLength": 1, "maxLength": 256}
        },
        "negativeEvidence": {
          "type": "array",
          "maxItems": 64,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["expectedSignal", "observer", "source", "windowStartUtc", "windowEndUtc", "observerActive", "sourceFresh", "observationComplete", "observed"],
            "properties": {
              "expectedSignal": {"type": "string", "minLength": 1, "maxLength": 256},
              "observer": {"type": "string", "minLength": 1, "maxLength": 256},
              "source": {"type": "string", "minLength": 1, "maxLength": 256},
              "windowStartUtc": {"type": "string", "format": "date-time"},
              "windowEndUtc": {"type": "string", "format": "date-time"},
              "observerActive": {"const": true},
              "sourceFresh": {"const": true},
              "observationComplete": {"const": true},
              "observed": {"const": false}
            }
          }
        },
        "lastMarkerBoundaryOnly": {"const": true},
        "balancedSpan": {"type": "boolean"},
        "unrelatedDoneClosedSpan": {"const": false},
        "causality": {
          "type": "object",
          "additionalProperties": false,
          "required": ["observation", "inference", "hypotheses", "provenCause", "rootCauseEvidenceRefs"],
          "properties": {
            "observation": {"type": "string", "minLength": 1, "maxLength": 4096},
            "inference": {"type": ["string", "null"], "maxLength": 4096},
            "hypotheses": {
              "type": "array",
              "maxItems": 32,
              "items": {"type": "string", "minLength": 1, "maxLength": 1024}
            },
            "provenCause": {"type": ["string", "null"], "maxLength": 4096},
            "rootCauseEvidenceRefs": {
              "type": "array",
              "maxItems": 32,
              "items": {"type": "string", "minLength": 1, "maxLength": 256}
            }
          },
          "allOf": [
            {
              "if": {
                "properties": {"provenCause": {"type": "string", "minLength": 1}},
                "required": ["provenCause"]
              },
              "then": {
                "properties": {"rootCauseEvidenceRefs": {"minItems": 1}}
              }
            }
          ]
        },
        "reconstructable": {"const": true}
      },
      "allOf": [
        {
          "if": {"properties": {"terminalStatus": {"const": "process_lost"}}, "required": ["terminalStatus"]},
          "then": {
            "properties": {
              "postState": {"type": "null"},
              "balancedSpan": {"const": false}
            }
          }
        },
        {
          "if": {"properties": {"terminalStatus": {"enum": ["completed", "error", "blocked", "aborted"]}}, "required": ["terminalStatus"]},
          "then": {
            "properties": {
              "postState": {"type": "object"},
              "completedAtUtc": {"type": "string", "format": "date-time"},
              "balancedSpan": {"const": true}
            }
          }
        }
      ]
    },
    "evidenceRefs": {
      "type": "array",
      "maxItems": 64,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["role", "sha256"],
        "properties": {
          "role": {"type": "string", "minLength": 1, "maxLength": 128},
          "sha256": {"type": "string", "pattern": "^[0-9a-fA-F]{64}$"},
          "sanitizedExcerpt": {"type": ["string", "null"], "maxLength": 12000}
        }
      }
    },
    "proofLevel": {"enum": ["contract", "harness", "static_test", "build", "launcher", "command_ack", "behavior_observed", "live_runtime"]},
    "redaction": {
      "type": "object",
      "additionalProperties": false,
      "required": ["sanitized", "containsSecrets", "containsSaveData", "containsAbsolutePersonalPaths", "rawLogsCommitted"],
      "properties": {
        "sanitized": {"const": true},
        "containsSecrets": {"const": false},
        "containsSaveData": {"const": false},
        "containsAbsolutePersonalPaths": {"const": false},
        "rawLogsCommitted": {"const": false}
      }
    },
    "nextDecision": {"type": "string", "minLength": 1, "maxLength": 2048}
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "failure": {
            "properties": {"crashObserved": {"const": true}},
            "required": ["crashObserved"]
          }
        },
        "required": ["failure"]
      },
      "then": {"required": ["crashObservability"]}
    },
    {
      "if": {
        "properties": {
          "failure": {
            "properties": {"classification": {"const": "native_crash_confirmed"}},
            "required": ["classification"]
          }
        },
        "required": ["failure"]
      },
      "then": {
        "required": ["crashObservability"],
        "properties": {
          "failure": {
            "required": ["externalTerminalEvidenceRefs"],
            "properties": {"externalTerminalEvidenceRefs": {"minItems": 1}}
          }
        }
      }
    }
  ]
}
