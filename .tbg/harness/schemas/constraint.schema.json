{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/EndeavorEverlasting/BlacksmithGuild/.tbg/harness/schemas/constraint.schema.json",
  "title": "TBG Constraint v1",
  "description": "An authority or prohibition that applies based on conditions.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "id",
    "appliesWhen",
    "rule",
    "authority",
    "severity"
  ],
  "properties": {
    "schema": {
      "const": "TbgConstraint.v1"
    },
    "id": {
      "type": "string",
      "pattern": "^constraint:[a-z0-9]+(?:-[a-z0-9]+)*$"
    },
    "appliesWhen": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "requestedProofAtLeast": {
          "enum": [
            "contract",
            "harness",
            "windows watcher harness",
            "static test",
            "build",
            "launcher",
            "command ACK",
            "behavior observed",
            "live runtime"
          ]
        },
        "riskClassAtLeast": {
          "enum": [
            "static",
            "local_read_write",
            "external_read_only",
            "runtime_read",
            "runtime_write",
            "destructive"
          ]
        },
        "activeSkills": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "always": {
          "type": "boolean"
        }
      }
    },
    "rule": {
      "type": "string",
      "minLength": 1
    },
    "authority": {
      "type": "string",
      "minLength": 1
    },
    "severity": {
      "enum": ["blocking", "warning"]
    },
    "scope": {
      "type": "array",
      "items": {
        "enum": [
          "contract",
          "harness",
          "windows watcher harness",
          "static test",
          "build",
          "launcher",
          "command ACK",
          "behavior observed",
          "live runtime"
        ]
      }
    },
    "status": {
      "enum": ["active", "inactive", "superseded"],
      "default": "active"
    },
    "version": {
      "type": "integer",
      "minimum": 1,
      "default": 1
    },
    "supersedes": {
      "type": "string"
    },
    "producedUtc": {
      "type": "string",
      "format": "date-time"
    }
  }
}
