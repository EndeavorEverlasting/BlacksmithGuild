{
  "schema": "tbg.one-click-test.catalog-entry.v1",
  "type": "object",
  "required": [
    "testId", "displayName", "ownerLane", "sourcePath",
    "command", "arguments", "supportedHosts", "requiredTools",
    "dependencies", "timeoutSeconds", "mutationClass", "riskClass",
    "proofLevel", "proofCeiling", "tags", "triggerInterests"
  ],
  "properties": {
    "testId": { "type": "string", "pattern": "^[a-z0-9]+(\\.[a-z0-9]+)+$" },
    "displayName": { "type": "string" },
    "ownerLane": { "type": "string" },
    "schema": { "type": "string", "enum": ["tbg.one-click-test.catalog-entry.v1"] },
    "sourcePath": { "type": "string" },
    "command": { "type": "string" },
    "arguments": {
      "type": "array",
      "items": { "type": "string" }
    },
    "supportedHosts": {
      "type": "array",
      "items": { "type": "string", "enum": ["win", "linux", "macos", "win_pwsh", "win_powershell"] }
    },
    "requiredTools": {
      "type": "array",
      "items": { "type": "string" }
    },
    "requiredInputs": {
      "type": "array",
      "items": { "type": "string" }
    },
    "dependencies": {
      "type": "array",
      "items": { "type": "string" }
    },
    "timeoutSeconds": { "type": "integer", "minimum": 1 },
    "mutationClass": {
      "type": "string",
      "enum": ["none", "read_only", "local_write", "runtime_read", "runtime_write", "deployment"]
    },
    "riskClass": {
      "type": "string",
      "enum": ["static", "local_read_write", "external_read_only", "runtime_read", "runtime_write", "destructive"]
    },
    "expectedArtifacts": {
      "type": "array",
      "items": { "type": "string" }
    },
    "proofLevel": {
      "type": "string",
      "enum": ["contract", "harness", "static test", "build", "launcher", "command ACK", "behavior observed", "live runtime"]
    },
    "proofCeiling": { "type": "string" },
    "tags": {
      "type": "array",
      "items": { "type": "string" }
    },
    "triggerInterests": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "eventType": { "type": "string" },
          "condition": { "type": "string" }
        }
      }
    },
    "defaultProfileMembership": {
      "type": "array",
      "items": { "type": "string" }
    },
    "sourceProvenance": {
      "type": "object",
      "properties": {
        "type": { "type": "string", "enum": ["repository", "pr", "developer", "agent", "script", "cert"] },
        "ref": { "type": "string" }
      }
    }
  }
}
