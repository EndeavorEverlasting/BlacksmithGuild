{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/EndeavorEverlasting/BlacksmithGuild/.tbg/harness/schemas/capability.schema.json",
  "title": "TBG Capability v1",
  "description": "What a skill, agent, workflow, or external tool is qualified and authorized to do.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "id",
    "providedBy",
    "consumes",
    "produces",
    "maxProofLevel",
    "riskClasses",
    "authorityRequirements"
  ],
  "properties": {
    "schema": {
      "const": "TbgCapability.v1"
    },
    "id": {
      "type": "string",
      "pattern": "^capability:[a-z0-9]+(?:-[a-z0-9]+)*$"
    },
    "providedBy": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "pattern": "^skill:"
      }
    },
    "consumes": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "produces": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "maxProofLevel": {
      "enum": [
        "contract",
        "harness",
        "windows watcher harness",
        "static test",
        "build",
        "launcher",
        "command ACK",
        "behavior observed",
        "live runtime"
      ]
    },
    "riskClasses": {
      "type": "array",
      "minItems": 1,
      "items": {
        "enum": [
          "static",
          "local_read_write",
          "external_read_only",
          "runtime_read",
          "runtime_write",
          "destructive"
        ]
      }
    },
    "authorityRequirements": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "version": {
      "type": "integer",
      "minimum": 1,
      "default": 1
    },
    "supersedes": {
      "type": "string"
    },
    "producedUtc": {
      "type": "string",
      "format": "date-time"
    }
  }
}
