{
  "id": "runtime-event-observation",
  "schemaVersion": "TbgWorkflowContract.v1",
  "sprint": "runtime-event-spine",
  "contextBanner": "[TBG | Sprint 2 | runtime event observation spine | launcher-to-campaign continuity specialized]",
  "purpose": "Define the canonical, read-only normalized event boundary shared by window, process, external-evidence, in-process-span, launcher-handoff, and campaign-readiness observers. Observation never implies action acceptance, root cause, campaign automation authority, or live-runtime proof.",
  "allowedScope": [
    "schemas, fixtures, static validator, registry and manifest wiring for runtime observation",
    "read-only normalization and artifact-shape validation",
    "sanitized local artifact path declaration",
    "same-run launcher-to-game observer attachment and readiness event correlation"
  ],
  "forbiddenScope": [
    "src/** or observer implementation",
    "process, game, launcher, command-inbox, save, or gameplay mutation",
    "incident cause assembly or native-crash confirmation from event presence alone",
    "campaign readiness or gameplay authority from launcher handoff MapTransition MapReady command ACK or trigger match alone",
    "raw dump, secret, token, or personal-path tracking"
  ],
  "sharedOutputRoot": ".local/tbg-runtime-observer/<runId>/",
  "requiredArtifacts": [
    "run-context.json",
    "handoff-context.json",
    "artifact-registry.json",
    "events.jsonl",
    "observer-status.json",
    "campaign-readiness.json",
    "campaign-readiness-cascade.json",
    "incident-timeline.json",
    "incident-result.json",
    "operator-report.md"
  ],
  "latestOutputRoot": "artifacts/latest/runtime-observer/",
  "schemas": {
    "runContext": ".tbg/harness/schemas/runtime-observer-run-context.schema.json",
    "event": ".tbg/harness/schemas/runtime-observer-event.schema.json",
    "artifactRegistry": ".tbg/harness/schemas/runtime-observer-artifact-registry.schema.json",
    "incidentTimeline": ".tbg/harness/schemas/runtime-incident-timeline.schema.json"
  },
  "continuitySpecialization": {
    "contract": ".tbg/workflows/launcher-to-campaign-event-continuity.contract.json",
    "preserveRunIdAcrossLauncherAndGame": true,
    "preserveCorrelationIdAcrossLauncherAndGame": true,
    "requireWindowAndRuntimeObserverOverlap": true,
    "windowObserverRetiresOnlyAfterRuntimeAttachmentAck": true,
    "sameProcessGameHostingSupported": true,
    "observerGapRequiresReconciliation": true,
    "launcherHandoffIsNotCampaignReadiness": true,
    "mapTransitionIsNotCampaignReadiness": true,
    "campaignCascadeRequiresStableReadinessGate": true,
    "readinessCascadeGrantsGameplayAuthority": false
  },
  "doctrine": {
    "eventPresenceIsNotAcceptanceOrCause": true,
    "lastOpenSpanIsBoundaryNotCause": true,
    "nativeCrashConfirmedRequiresCorrelatedExternalTerminalEvidence": true,
    "staleOrIncompleteSilenceIsNotNegativeEvidence": true,
    "triggerMatchIsRoutingNotAuthority": true
  },
  "validationCommands": [
    "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/tbg/Test-TbgLauncherToCampaignContinuity.ps1",
    "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/tbg/Test-TbgRuntimeEventObservation.ps1",
    "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/tbg/Test-TbgRuntimeContextContinuity.ps1",
    "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/tbg/Test-TbgHarnessDoctrine.ps1",
    "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/tbg/Test-TbgTriggerFragments.ps1",
    "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/tbg/Test-TbgEndToEndHarness.ps1",
    "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/test-agent-coordination-contract.ps1",
    "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/test-powershell-utf8-bom-contract.ps1",
    "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/tbg/Invoke-TbgEndToEndValidation.ps1 -Profile default-static",
    "git diff --check"
  ],
  "proofCeiling": "static_test",
  "terminalStates": [
    "PASS_runtime_event_spine_static_validated",
    "BLOCKED_contract_or_registry_missing",
    "BLOCKED_OBSERVER_CONTINUITY_MISSING",
    "BLOCKED_CAMPAIGN_READINESS_GATE_MISSING",
    "FAIL_fixture_or_doctrine_violation"
  ]
}
