#!/usr/bin/env bash
#
# BlacksmithGuild local pre-commit hook
# Blocks generated evidence, crash dumps, secrets, and machine-local junk.
# Does NOT execute runtime, launcher, or network activity.
# Does NOT print sensitive file contents.
#
set -euo pipefail

REPO_ROOT="$(git rev-parse --show-toplevel)"
EXIT_CODE=0
BLOCKED=0

# --- blocked path patterns (regex, case-insensitive) ---
BLOCKED_PATTERNS=(
  '\.(dmp|hdmp|crash)$'
  '\.(tmp|bak|swp|swo)$'
  '(^|/)\~$'
  '(^|/)(core|core\.\d+)$'
  '(^|/)\.env(\.|$)'
  '(^|/)(credentials|secrets)\.json$'
  '\.(pem|key|p12|pfx)$'
  '(^|/)node_modules/'
  '(^|/)\.codex/'
  '(^|/)\.gemini/'
  '(^|/)BlacksmithGuild_[A-Z][A-Za-z]+\.json$'
  '(^|/)BlacksmithGuild_[A-Z][A-Za-z]+\.log$'
  '(^|/)BlacksmithGuild_[A-Z][A-Za-z]+\.lock$'
  '(^|/)tools/LaunchControl/Launch-Control\.generated\.local\.json$'
  '(^|/)tools/LaunchControl/TASKBAR-PINNING\.txt$'
  '(^|/)BlacksmithGuild_Status\.json$'
  '(^|/)BlacksmithGuild_CommandInbox\.json$'
  '(^|/)BlacksmithGuild_CommandAck\.json$'
  '(^|/)BlacksmithGuild_PendingReload\.json$'
  '(^|/)BlacksmithGuild_TreasuryWatch\.json$'
  '(^|/)BlacksmithGuild_ForgeRecommendations\.json$'
  '(^|/)BlacksmithGuild_RecipeProbe\.json$'
  '(^|/)BlacksmithGuild_AutoCharacterBuild\.json$'
  '(^|/)BlacksmithGuild_Launch\.log$'
  '(^|/)BlacksmithGuild_Launch\.lock$'
  '(^|/)BlacksmithGuild_LaunchIntent\.json$'
  '(^|/)BlacksmithGuild_ProcessLifecycle\.json$'
  '(^|/)BlacksmithGuild_CancelRun\.json$'
  '(^|/)BlacksmithGuild_AssistToggle\.json$'
  '(^|/)BlacksmithGuild_RuntimeLifecycle\.json$'
  '(^|/)BlacksmithGuild_RuntimeRegent\.json$'
  '(^|/)BlacksmithGuild_Phase1\.log$'
  '(^|/)BlacksmithGuild_Launch\.log$'
)

# --- allowed path exceptions (sanitized fixtures, docs, evidence manifests) ---
ALLOWED_PATTERNS=(
  '(^|/)docs/evidence/'
  '(^|/)docs/evidence/latest/'
  '(^|/)\.tbg/harness/fixtures/'
  '(^|/)artifacts/latest/'
  '(^|/)docs/architecture/'
  '(^|/)docs/handoff/'
  '(^|/)docs/plans/'
  '(^|/)\.tbg/state/generated/'
)

STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM 2>/dev/null || true)

if [ -z "$STAGED_FILES" ]; then
  exit 0
fi

blocked_files=""

while IFS= read -r file; do
  [ -z "$file" ] && continue
  is_blocked=0
  is_allowed=0

  for pattern in "${ALLOWED_PATTERNS[@]}"; do
    if echo "$file" | grep -qiE "$pattern" 2>/dev/null; then
      is_allowed=1
      break
    fi
  done

  if [ "$is_allowed" -eq 1 ]; then
    continue
  fi

  for pattern in "${BLOCKED_PATTERNS[@]}"; do
    if echo "$file" | grep -qiE "$pattern" 2>/dev/null; then
      is_blocked=1
      break
    fi
  done

  if [ "$is_blocked" -eq 1 ]; then
    blocked_files="${blocked_files}  ${file}\n"
    BLOCKED=1
  fi
done <<< "$STAGED_FILES"

if [ "$BLOCKED" -eq 1 ]; then
  echo ""
  echo "[harness] refusing staged generated/runtime artifact(s):"
  echo ""
  printf "$blocked_files"
  echo ""
  echo "Move live/generated evidence back to ignored local output,"
  echo "or commit a sanitized fixture under an approved fixture/docs path."
  echo ""
  echo "Blocked patterns include: crash dumps, temp/swap files, secrets,"
  echo "generated runtime BlacksmithGuild JSON/logs, node_modules, and"
  echo "machine-local tool caches."
  echo ""
  echo "To unstage a file:  git restore --staged <path>"
  echo "To ignore broadly:  add the pattern to .gitignore"
  echo ""
  exit 1
fi

exit 0
