{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Build + Install",
      "type": "shell",
      "command": "dotnet",
      "args": [
        "build",
        "src/BlacksmithGuild/BlacksmithGuild.csproj",
        "-c",
        "Release"
      ],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": "$msCompile",
      "presentation": {
        "reveal": "silent",
        "panel": "shared"
      }
    },
    {
      "label": "Forge Watch",
      "type": "shell",
      "command": "powershell",
      "args": [
        "-NoProfile",
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "${workspaceFolder}/forge.ps1",
        "-Watch"
      ],
      "isBackground": true,
      "problemMatcher": "$msCompile",
      "presentation": {
        "reveal": "always",
        "panel": "dedicated"
      }
    }
  ]
}
