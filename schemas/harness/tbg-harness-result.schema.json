{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/EndeavorEverlasting/BlacksmithGuild/schemas/harness/tbg-harness-result.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "run_id", "profile", "status", "proof_level", "proof_ceiling", "journeys", "artifacts"],
  "properties": {
    "schema_version": {"const": "tbg-harness-result/v1"}, "run_id": {"type": "string", "minLength": 1}, "profile": {"type": "string", "minLength": 1},
    "status": {"enum": ["completed", "blocked", "failed"]}, "proof_level": {"type": "string", "minLength": 1}, "proof_ceiling": {"type": "string", "minLength": 1},
    "journeys": {"type": "array"}, "artifacts": {"type": "array"}
  }
}
